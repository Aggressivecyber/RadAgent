flowchart TB

    %% G4 Codegen 子图
    %% 粗粒度 Agent 代码生成流水线 (2 层模块 + 最终集成 + 运行/物理审核)

    load_model_ir["加载 Model IR"] :::entry
    build_codegen_plan("代码生成规划")
    plan_geometry_strategy("几何策略规划")
    plan_code_architecture("架构规划")
    build_module_contracts("模块契约")
    build_module_contexts("模块上下文")
    run_core_modules("生成核心模块")
    core_modules_gate{{"核心层一致性"}}
    coordinate_core_modules_context("协调核心上下文")
    run_runtime_modules("生成运行模块")
    runtime_modules_gate{{"运行层一致性"}}
    coordinate_runtime_modules_context("协调运行上下文")
    build_interface_contracts("接口契约")
    integration_assembler("集成组装")
    global_integration_agent("最终集成 Agent")
    runtime_execution_audit{{"运行真实性审核"}}
    physics_quality_review{{"物理质量审核"}}
    persist_codegen_output["持久化输出"]

    load_model_ir --> build_codegen_plan
    build_codegen_plan --> plan_geometry_strategy
    plan_geometry_strategy --> plan_code_architecture
    plan_code_architecture --> build_module_contracts
    build_module_contracts --> build_module_contexts
    build_module_contexts --> run_core_modules
    run_core_modules --> core_modules_gate
    coordinate_core_modules_context --> run_runtime_modules
    run_runtime_modules --> runtime_modules_gate
    coordinate_runtime_modules_context --> build_interface_contracts
    build_interface_contracts --> integration_assembler
    integration_assembler --> global_integration_agent
    global_integration_agent --> runtime_execution_audit
    physics_quality_review --> persist_codegen_output
    persist_codegen_output --> END((END))

    %% Conditional routes
    core_modules_gate --> |通过|coordinate_core_modules_context
    core_modules_gate ==> |失败|persist_codegen_output
    runtime_modules_gate --> |通过|coordinate_runtime_modules_context
    runtime_modules_gate ==> |失败|persist_codegen_output
    runtime_execution_audit --> |通过|physics_quality_review
    runtime_execution_audit ==> |失败|persist_codegen_output

    %% Node styles
    classDef codegen fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px,color:#333
    classDef guard fill:#FCE4EC,stroke:#C62828,stroke-width:2px,color:#333
    classDef io fill:#FFF3E0,stroke:#F57C00,stroke-width:2px,color:#333
