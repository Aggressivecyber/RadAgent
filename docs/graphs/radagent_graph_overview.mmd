flowchart TB

    initialize_request["初始化请求"] :::entry
    intent_router{{"意图路由"}}
    chat_response_node("聊天响应")
    prepare_workspace("准备工作区")

    subgraph context_subgraph
        direction TB
        route_sources["路由源选择"]
        retrieve_rag_context("RAG 上下文检索")
        score_rag_context{{"RAG 评分"}}
        retrieve_web_context("Web 补充检索")
        score_combined_context{{"综合评分"}}
        save_evidence_map["保存证据映射"]
        route_sources --> retrieve_rag_context
        retrieve_rag_context --> score_rag_context
        retrieve_web_context --> score_combined_context
        score_combined_context --> save_evidence_map
        save_evidence_map --> context_subgraph_end((END))
    end

    subgraph task_planning_subgraph
        direction TB
        parse_task("解析任务")
        validate_task_spec{{"验证任务规格"}}
        save_task_spec["保存任务规格"]
        parse_task --> validate_task_spec
        save_task_spec --> task_planning_subgraph_end((END))
    end

    subgraph g4_modeling_subgraph
        direction TB
        load_task_spec["加载任务规格"]
        requirement_capture_node("需求捕获")
        evidence_retrieval_node("证据检索")
        model_scope_guard_node{{"Scope Guard"}}
        geometry_decomposition_node("几何分解")
        coordinate_system_node("坐标系定义")
        material_definition_node("材料定义")
        source_definition_node("源定义")
        physics_list_node("物理列表")
        sensitive_detector_node("灵敏探测器")
        scoring_design_node("Scoring 设计")
        model_ir_validation_node{{"Model IR 校验"}}
        model_review_report_node("模型审查报告")
        persist_model_ir["持久化 Model IR"]
        load_task_spec --> requirement_capture_node
        requirement_capture_node --> evidence_retrieval_node
        evidence_retrieval_node --> model_scope_guard_node
        geometry_decomposition_node --> coordinate_system_node
        coordinate_system_node --> material_definition_node
        material_definition_node --> source_definition_node
        source_definition_node --> physics_list_node
        physics_list_node --> sensitive_detector_node
        sensitive_detector_node --> scoring_design_node
        scoring_design_node --> model_ir_validation_node
        model_review_report_node --> persist_model_ir
        persist_model_ir --> g4_modeling_subgraph_end((END))
    end

    subgraph human_confirmation_subgraph
        direction TB
        build_proposed_model_completion("构建待确认模型")
        generate_confirmation_request("生成确认请求")
        human_interrupt_node{{"等待人工输入"}}
        parse_confirmation_response("解析确认回复")
        merge_user_confirmation("合并确认结果")
        validate_confirmation_completeness{{"校验确认完整性"}}
        build_proposed_model_completion --> generate_confirmation_request
        generate_confirmation_request --> human_interrupt_node
        parse_confirmation_response --> merge_user_confirmation
    end

    subgraph g4_codegen_subgraph
        direction TB
        load_model_ir["加载 Model IR"]
        build_codegen_plan("代码生成规划")
        plan_geometry_strategy("几何策略规划")
        plan_code_architecture("架构规划")
        build_module_contracts("模块契约")
        build_module_contexts("模块上下文")
        run_core_modules("生成核心模块")
        core_modules_gate{{"核心层一致性"}}
        coordinate_core_modules_context("协调核心上下文")
        run_runtime_modules("生成运行模块")
        runtime_modules_gate{{"运行层一致性"}}
        coordinate_runtime_modules_context("协调运行上下文")
        build_interface_contracts("接口契约")
        integration_assembler("集成组装")
        global_integration_agent("最终集成 Agent")
        runtime_execution_audit{{"运行真实性审核"}}
        physics_quality_review{{"物理质量审核"}}
        persist_codegen_output["持久化输出"]
        load_model_ir --> build_codegen_plan
        build_codegen_plan --> plan_geometry_strategy
        plan_geometry_strategy --> plan_code_architecture
        plan_code_architecture --> build_module_contracts
        build_module_contracts --> build_module_contexts
        build_module_contexts --> run_core_modules
        run_core_modules --> core_modules_gate
        coordinate_core_modules_context --> run_runtime_modules
        run_runtime_modules --> runtime_modules_gate
        coordinate_runtime_modules_context --> build_interface_contracts
        build_interface_contracts --> integration_assembler
        integration_assembler --> global_integration_agent
        global_integration_agent --> runtime_execution_audit
        physics_quality_review --> persist_codegen_output
        persist_codegen_output --> g4_codegen_subgraph_end((END))
    end

    subgraph gate_validation_subgraph
        direction TB
        load_gate_inputs["加载门禁输入"]
        run_base_gates{{"基础门禁 0-11"}}
        run_g4_modeling_gates{{"G4 门禁 A-H"}}
        finalize_gate_results{{"汇总结果"}}
        load_gate_inputs --> run_base_gates
        run_base_gates --> run_g4_modeling_gates
        run_g4_modeling_gates --> finalize_gate_results
        finalize_gate_results --> gate_validation_subgraph_end((END))
    end

    subgraph patch_subgraph
        direction TB
        load_proposed_patch["加载 Patch"]
        review_patch{{"审查 Patch"}}
        apply_patch("应用 Patch")
        load_proposed_patch --> review_patch
        review_patch --> apply_patch
        apply_patch --> patch_subgraph_end((END))
    end

    subgraph artifact_subgraph
        direction TB
        collect_artifacts("收集产物")
        generate_artifact_manifest("生成 Manifest")
        generate_artifact_readme("生成 README")
        collect_artifacts --> generate_artifact_manifest
        generate_artifact_manifest --> generate_artifact_readme
        generate_artifact_readme --> artifact_subgraph_end((END))
    end

    subgraph report_subgraph
        direction TB
        generate_final_report("生成最终报告")
        generate_final_report --> report_subgraph_end((END))
    end

    %% Main graph routing
    initialize_request --> intent_router
    chat_response_node --> END((END))
    prepare_workspace --> context_subgraph
    report_subgraph --> END((END))

    intent_router --> |chat|chat_response_node
    intent_router --> |确认回复|human_confirmation_subgraph
    intent_router --> |simulation_work|prepare_workspace
    context_subgraph --> |充分 → 规划|task_planning_subgraph
    context_subgraph ==> |不足 → 报告|report_subgraph
    task_planning_subgraph --> |scope=geant4|g4_modeling_subgraph
    task_planning_subgraph ==> |TCAD/SPICE/失败|report_subgraph
    g4_modeling_subgraph --> |需确认|human_confirmation_subgraph
    g4_modeling_subgraph --> |通过且无需确认|g4_codegen_subgraph
    g4_modeling_subgraph ==> |失败|report_subgraph
    human_confirmation_subgraph --> |确认完成|g4_codegen_subgraph
    human_confirmation_subgraph -.-> |补充信息|context_subgraph
    human_confirmation_subgraph ==> |拒绝/失败/待输入|report_subgraph
    g4_codegen_subgraph --> |通过|patch_subgraph
    g4_codegen_subgraph ==> |失败|report_subgraph
    patch_subgraph --> |已应用|gate_subgraph
    patch_subgraph ==> |失败|report_subgraph
    gate_subgraph --> |passed|artifact_subgraph
    gate_subgraph -.-> |Gate 0 失败|context_subgraph
    gate_subgraph -.-> |Gate 1 失败|task_planning_subgraph
    gate_subgraph -.-> |Gate 2/G4-A~E 失败|g4_modeling_subgraph
    gate_subgraph -.-> |G4-H 失败|human_confirmation_subgraph
    gate_subgraph -.-> |Gate 5~9/11/G4-F~G 失败|g4_codegen_subgraph
    gate_subgraph -.-> |Gate 3~4 失败|patch_subgraph
    gate_subgraph ==> |retry≥5 或其他|report_subgraph
    artifact_subgraph --> report_subgraph

    %% Node styles
    classDef artifact fill:#E0F7FA,stroke:#00838F,stroke-width:2px,color:#333
    classDef guard fill:#FCE4EC,stroke:#C62828,stroke-width:2px,color:#333
    classDef io fill:#FFF3E0,stroke:#F57C00,stroke-width:2px,color:#333
    classDef workspace fill:#E8F5E9,stroke:#388E3C,stroke-width:2px,color:#333
