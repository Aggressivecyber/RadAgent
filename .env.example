# LLM Configuration
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Or use Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx
# MODEL_NAME=claude-sonnet-4-20250514

# Or use DeepSeek
# OPENAI_API_KEY=sk-deepseek-xxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat
# RADAGENT_NAMING_MODEL=deepseek-v4-lite  # Model for job title generation (default: deepseek-v4-lite)

# RAG Configuration (standard logical names)
GEANT4_RAG_ENDPOINT=http://localhost:8000/geant4
TCAD_RAG_ENDPOINT=http://localhost:8000/tcad
SPICE_RAG_ENDPOINT=http://localhost:8000/spice

# Web Search (optional — DuckDuckGo is default, no key needed)
# EXA_API_KEY=exa-xxx
# DISABLE_WEB_SEARCH=1

# Simulation Environment
GEANT4_INSTALL_DIR=/usr/local/geant4
NGSPICE_BIN=/usr/local/bin/ngspice
TCAD_DOCKER_CONTAINER=tcad-sentaurus

# Workspace
SIMULATION_WORKSPACE=./simulation_workspace
