# Model Gateway Configuration (unified LLM access)
# Base URL for all model tiers (OpenAI-compatible API)
RADAGENT_MODEL_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
RADAGENT_ENABLE_MODEL_TIMEOUTS=1
RADAGENT_ENABLE_MODEL_STREAMING=1

# API key for the configured OpenAI-compatible endpoint.
# MiMo Token Plan and other compatible endpoints use this same project config.
# RADAGENT_API_KEY=<api-key>
# RADAGENT_LITE_API_KEY_ENV=RADAGENT_API_KEY
# RADAGENT_PRO_API_KEY_ENV=RADAGENT_API_KEY
# RADAGENT_MAX_API_KEY_ENV=RADAGENT_API_KEY

# Lite tier (intent routing, simple extraction, naming)
RADAGENT_MODEL_LITE=mimo-v2.5
RADAGENT_LITE_TIMEOUT_S=30
RADAGENT_LITE_MAX_TOKENS=2048
RADAGENT_LITE_CONTEXT_WINDOW_TOKENS=1000000

# Pro tier (task planning, modeling, codegen)
RADAGENT_MODEL_PRO=mimo-v2.5-pro
RADAGENT_PRO_TIMEOUT_S=360
RADAGENT_PRO_MAX_TOKENS=8192
RADAGENT_PRO_CONTEXT_WINDOW_TOKENS=1000000

# Max tier (final review, gate diagnosis)
RADAGENT_MODEL_MAX=mimo-v2.5-pro
RADAGENT_MAX_TIMEOUT_S=420
RADAGENT_MAX_MAX_TOKENS=12000
RADAGENT_MAX_CONTEXT_WINDOW_TOKENS=1000000

# Agent loops: 0/unset means no fixed small history cap; compress at ~75% of model window.
RADAGENT_AGENTIC_HISTORY_CHARS=0

# RAG Configuration (standard logical names)
GEANT4_RAG_ENDPOINT=http://localhost:8000/geant4
TCAD_RAG_ENDPOINT=http://localhost:8000/tcad
# Optional external SPICE RAG service; no local SPICE knowledge base is bundled.
# SPICE_RAG_ENDPOINT=http://localhost:8000/spice

# Web Search (optional — DuckDuckGo is default, no key needed)
# EXA_API_KEY=exa-xxx
# DISABLE_WEB_SEARCH=1

# Simulation Environment
GEANT4_INSTALL_DIR=/usr/local/geant4
GEANT4_CONFIG_BIN=/usr/local/geant4/bin/geant4-config
GEANT4_SETUP_SCRIPT=/etc/profile.d/geant4.sh
# Optional: override Geant4 example source tree used by codegen/RAG tools.
# RADAGENT_GEANT4_EXAMPLES_ROOT=/usr/local/geant4/share/Geant4/examples
CMAKE_BIN=/usr/bin/cmake
NGSPICE_BIN=/usr/local/bin/ngspice

# TCAD/Sentaurus. Use either a local install path/tool binaries or Docker.
TCAD_INSTALL_DIR=/path/to/synopsys/tcad
TCAD_DOCKER_CONTAINER=tcad-sentaurus
TCAD_SDE_BIN=/path/to/sde
TCAD_SVISUAL_BIN=/path/to/svisual
TCAD_SWB_BIN=/path/to/swb
TCAD_INSPECT_BIN=/path/to/inspect

PYTHON_BIN=.venv/bin/python

# Workspace
SIMULATION_WORKSPACE=./simulation_workspace
