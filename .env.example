# LLM Configuration
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# Or use Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxx
# MODEL_NAME=claude-sonnet-4-20250514

# RAG Configuration
G4RAG_MCP_ENDPOINT=http://localhost:8000/g4rag
TCADRAG_MCP_ENDPOINT=http://localhost:8000/tcadrag
SPICERAG_MCP_ENDPOINT=http://localhost:8000/spicerag

# Simulation Environment
GEANT4_INSTALL_DIR=/usr/local/geant4
NGSPICE_BIN=/usr/local/bin/ngspice
TCAD_DOCKER_CONTAINER=tcad-sentaurus

# Workspace
SIMULATION_WORKSPACE=./simulation_workspace
