# Model Gateway Configuration (unified LLM access)
# Base URL for all model tiers (OpenAI-compatible API)
RADAGENT_MODEL_BASE_URL=https://api.deepseek.com/v1

# API Key (required)
RADAGENT_API_KEY=sk-xxx

# Lite tier (intent routing, simple extraction, naming)
RADAGENT_MODEL_LITE=deepseek-v4-lite
RADAGENT_LITE_TIMEOUT_S=30
RADAGENT_LITE_MAX_TOKENS=2048

# Pro tier (task planning, modeling, codegen)
RADAGENT_MODEL_PRO=deepseek-v4-pro
RADAGENT_PRO_TIMEOUT_S=90
RADAGENT_PRO_MAX_TOKENS=8192

# Max tier (final review, gate diagnosis) - currently same as pro, upgrade later
RADAGENT_MODEL_MAX=deepseek-v4-pro
RADAGENT_MAX_TIMEOUT_S=120
RADAGENT_MAX_MAX_TOKENS=12000

# Legacy LLM Configuration (deprecated - use model gateway above)
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o

# RAG Configuration (standard logical names)
GEANT4_RAG_ENDPOINT=http://localhost:8000/geant4
TCAD_RAG_ENDPOINT=http://localhost:8000/tcad
SPICE_RAG_ENDPOINT=http://localhost:8000/spice

# Web Search (optional — DuckDuckGo is default, no key needed)
# EXA_API_KEY=exa-xxx
# DISABLE_WEB_SEARCH=1

# Simulation Environment
GEANT4_INSTALL_DIR=/usr/local/geant4
NGSPICE_BIN=/usr/local/bin/ngspice
TCAD_DOCKER_CONTAINER=tcad-sentaurus

# Workspace
SIMULATION_WORKSPACE=./simulation_workspace
