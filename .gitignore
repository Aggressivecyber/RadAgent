# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/

# Ruff cache
.ruff_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/

# Environment variables
.env

# Simulation workspace (generated at runtime)
simulation_workspace/jobs/*/
simulation_workspace/simulation_workspace/

# Keep .gitkeep for directory structure
!simulation_workspace/jobs/.gitkeep

# Knowledge base data files (too large for git)
knowledge_base/**/data/
knowledge_base/**/__pycache__/
knowledge_base/**/.ruff_cache/

# Review artifacts — lightweight review bundle (must be committable)
# All files under review_artifacts/*/latest/ are kept small (<100KB each)
# and contain only summaries, CSV headers, and metadata — never raw data.
# review_artifacts/*/latest/** is explicitly allowed for commit.

# Still block large binary / raw simulation data
review_artifacts/*/latest/**/*.root
review_artifacts/*/latest/**/*.hdf5
review_artifacts/*/latest/**/*.h5
review_artifacts/*/latest/**/*.raw
review_artifacts/*/latest/**/*.bin

# OS
.DS_Store
Thumbs.db
