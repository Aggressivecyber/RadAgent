# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environment
.venv/
venv/

# IDE
.vscode/
.idea/

# Ruff cache
.ruff_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/

# MyPy
.mypy_cache/

# Environment variables
.env

# Simulation workspace (generated at runtime)
simulation_workspace/jobs/*/
simulation_workspace/simulation_workspace/

# Keep .gitkeep for directory structure
!simulation_workspace/jobs/.gitkeep

# Knowledge base data files (too large for git)
knowledge_base/**/data/
knowledge_base/**/__pycache__/
knowledge_base/**/.ruff_cache/

# Review artifacts (generated at runtime, only keep READMEs)
review_artifacts/*/latest/output/
review_artifacts/*/latest/*.json
!review_artifacts/*/latest/README.md

# OS
.DS_Store
Thumbs.db
