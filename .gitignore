.ruff_cache/

# Testing
.pytest_cache/
.coverage
htmlcov/

# Generated graph viewer artifacts
docs/graphs/*.html
docs/graphs/*.png
docs/graphs/langgraph_current/

# Local repair/debug logs
repair_logs/

# MyPy
.mypy_cache/

# Environment variables
.env

# Simulation workspace (NEVER commit job data)
simulation_workspace/

# Knowledge base data files (too large for git)
knowledge_base/**/data/
knowledge_base/**/__pycache__/
knowledge_base/**/.ruff_cache/

# Review artifacts — only latest summaries are committable
# Block all binary/raw simulation data
review_artifacts/**/*.root
review_artifacts/**/*.hdf5
review_artifacts/**/*.h5
review_artifacts/**/*.raw
review_artifacts/**/*.bin

# Archive old artifacts (keep .gitkeep for directory structure)
review_artifacts/archive/*
!review_artifacts/archive/.gitkeep
!review_artifacts/archive/**/.gitkeep

# OS
.DS_Store
Thumbs.db
.env
