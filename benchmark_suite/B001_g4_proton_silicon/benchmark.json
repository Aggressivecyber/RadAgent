{
  "benchmark_id": "B001",
  "name": "g4_proton_silicon",
  "description": "Geant4 proton on silicon energy deposition benchmark",
  "input": {
    "user_query": "模拟 10 MeV 质子垂直入射 300 微米硅片，输出能量沉积和剂量分布",
    "expected_task_spec": {
      "simulation_scope": ["geant4"],
      "particle": {"type": "proton", "energy_MeV": 10.0},
      "target": {"material": "Si", "size_um": [1000.0, 1000.0, 300.0]},
      "outputs": ["energy_deposition", "dose_distribution"]
    }
  },
  "expected_outputs": {
    "files": ["CMakeLists.txt", "geant4_sim.cc", "edep_3d.csv", "dose_3d.csv"],
    "gates": {
      "gate_0_rag_sufficiency": "pass",
      "gate_1_task_spec_schema": "pass",
      "gate_5_static_check": "pass"
    },
    "physics": {
      "no_negative_energy": true,
      "no_nan": true,
      "total_edep_gt_zero": true
    }
  },
  "tolerance": {
    "energy_deposition_relative_error": 0.10,
    "dose_relative_error": 0.10
  }
}
